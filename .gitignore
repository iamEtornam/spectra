# Dart build artifacts
.dart_tool/*
pubspec.lock
build/

# macOS / IDE noise
.DS_Store
.idea/
*.iml
.vscode/

# Sample project workspace used during development
bin/.spectra

# Spectra runtime artifacts at the repo root.
# Living-memory files (PROJECT.md, ROADMAP.md, PLAN.md, ...) are intentionally
# *not* ignored so users of `spectra new` can commit them. Only ignore the
# generated subtrees and live snapshot files.
/.spectra/runs/
/.spectra/workspaces/
/.spectra/RUNTIME.json
/.spectra/AGENTS.json
/.spectra/cache.json
